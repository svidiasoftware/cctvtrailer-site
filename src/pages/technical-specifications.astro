---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LazyImage from '../components/LazyImage.astro';
import Analytics from '../components/Analytics.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import VideoSchema from '../components/VideoSchema.astro';
import DefinitionSchema from '../components/DefinitionSchema.astro';
import RentVsBuy from '../components/RentVsBuy.astro';

const techSpecsSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "CCTV Mobile Security Trailer",
  "description": "Advanced mobile surveillance trailer with solar power, infrared PTZ cameras, and S-VIDIA technology. Weatherproof construction designed for Pacific Northwest climate with 360-degree coverage capability.",
  "brand": {
    "@type": "Brand",
    "name": "CCTV Trailer"
  },
  "image": [
    "https://www.cctvtrailer.com/images/trailer-1x1.png",
    "https://www.cctvtrailer.com/images/trailer-4x3.png",
    "https://www.cctvtrailer.com/images/trailer-16x9.png",
  ],
  "manufacturer": {
    "@type": "Organization",
    "name": "CCTV Trailer",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Tacoma",
      "addressRegion": "WA",
      "addressCountry": "US",
      "postalCode": "98401"
    }
  },
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "USD",
    "lowPrice": "3499",
    "highPrice": "4000",
    "offerCount": "2",
    "availability": "https://schema.org/InStock"
  },
  "additionalProperty": [
    {
      "@type": "PropertyValue",
      "name": "Camera System",
      "value": "Up to 4 cameras (PTZ, Fixed, 360-degree) with infrared night vision"
    },
    {
      "@type": "PropertyValue",
      "name": "Power Options",
      "value": "Solar panels, battery backup, gas generator, shore power connection"
    },
    {
      "@type": "PropertyValue",
      "name": "Connectivity",
      "value": "4G/5G, Wi-Fi, Starlink transmission options"
    },
    {
      "@type": "PropertyValue",
      "name": "Storage Capacity",
      "value": "2 weeks continuous recording with automatic looping"
    },
    {
      "@type": "PropertyValue",
      "name": "Construction",
      "value": "Reinforced steel, weatherproof, vandal-resistant"
    },
    {
      "@type": "PropertyValue",
      "name": "Mast Height",
      "value": "Adjustable electric/hydraulic mast"
    },
    {
      "@type": "PropertyValue",
      "name": "Security Features",
      "value": "Hitch lock, wheel locks, optional security boot"
    },
    {
      "@type": "PropertyValue",
      "name": "Platform",
      "value": "S-VIDIA video security platform with remote access"
    },
    {
      "@type": "PropertyValue",
      "name": "Optional Features",
      "value": "PA speakers, radar detection (400+ ft), LED floodlights, license plate reader"
    },
    {
      "@type": "PropertyValue",
      "name": "Towing Capability",
      "value": "Tow-capable up to 70 mph"
    }
  ],
  "category": "Security Equipment",
  "keywords": "mobile surveillance trailer, security camera trailer, construction site security, S-VIDIA technology, solar powered surveillance",
  "releaseDate": "2026-05-12",
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Pierce County, WA" },
    { "@type": "AdministrativeArea", "name": "King County, WA" },
    { "@type": "AdministrativeArea", "name": "Snohomish County, WA" },
    { "@type": "AdministrativeArea", "name": "Kitsap County, WA" }
  ]
};

// Breadcrumb data
const breadcrumbItems = [
  { name: "Home", url: "/" },
  { name: "Technical Specifications" }
];

// Video data for the YouTube video
const videoData = {
  name: "CCTV Trailer Mobile Security System Overview",
  description: "Professional overview of our mobile surveillance trailer systems, showcasing advanced features including PTZ cameras, solar power, S-VIDIA technology, and weatherproof construction designed for Pacific Northwest deployment.",
  thumbnailUrl: [
    "https://img.youtube.com/vi/WZh4h-t1D18/maxresdefault.jpg",
    "https://img.youtube.com/vi/WZh4h-t1D18/hqdefault.jpg"
  ],
  uploadDate: "2025-05-01T00:00:00-07:00",
  duration: "PT2M30S",
  contentUrl: "https://www.youtube.com/watch?v=WZh4h-t1D18",
  embedUrl: "https://www.youtube-nocookie.com/embed/WZh4h-t1D18",
  keywords: ["mobile surveillance trailer", "CCTV trailer", "security system", "construction site security", "PTZ cameras", "S-VIDIA technology"],
  genre: "Security Technology"
};

// Definition schemas for key technical terms
const definitions = [
  {
    term: "Mobile Surveillance Trailer",
    definition: "A portable, self-contained security system mounted on a wheeled trailer platform that provides comprehensive video surveillance capabilities for temporary or permanent deployment at various locations. These trailers feature cameras, power systems, and communication equipment.",
    category: "Security Equipment",
    relatedTerms: ["CCTV Trailer", "Security Trailer", "Mobile Security Unit"],
    url: "/technical-specifications"
  },
  {
    term: "PTZ Camera",
    definition: "Pan-Tilt-Zoom camera capable of remote directional and zoom control, allowing operators to actively track subjects and adjust viewing angles across a wide area. PTZ cameras provide 360-degree coverage with optical zoom capabilities.",
    category: "Surveillance Technology",
    relatedTerms: ["Security Camera", "Surveillance Camera", "Infrared Camera"],
    url: "/technical-specifications"
  },
  {
    term: "S-VIDIA Compression",
    definition: "Advanced video compression technology that reduces bandwidth requirements while maintaining high-quality surveillance footage. S-VIDIA enables efficient transmission of video data over cellular, Wi-Fi, and satellite networks without compromising image clarity.",
    category: "Video Technology",
    relatedTerms: ["Video Compression", "Data Transmission", "Bandwidth Optimization"],
    url: "/video-technology"
  },
  {
    term: "Solar-Powered Security",
    definition: "Surveillance systems powered by photovoltaic solar panels that convert sunlight into electrical energy, providing sustainable, off-grid operation with battery backup for continuous 24/7 monitoring without reliance on external power sources.",
    category: "Power Systems",
    relatedTerms: ["Renewable Energy", "Off-Grid Security", "Solar Panels"],
    url: "/technical-specifications"
  },
  {
    term: "Construction Site Security",
    definition: "Comprehensive security measures designed to protect construction sites from theft, vandalism, and unauthorized access, including physical barriers, surveillance systems, access control, and monitoring services to safeguard equipment, materials, and work progress.",
    category: "Security Services",
    relatedTerms: ["Site Security", "Jobsite Protection", "Construction Surveillance"],
    url: "/construction-security"
  }
];
---

<Layout 
  title="Mobile Surveillance Trailer Specs · 4K PTZ · Solar Power"
  description="Mobile surveillance trailer specs: 4K PTZ cameras, 360° coverage, solar power, same-day setup. Built for Pacific Northwest. Call (253) 683-2288."
  schema={JSON.stringify(techSpecsSchema)}
>

  <BreadcrumbSchema items={breadcrumbItems} />
  <VideoSchema {...videoData} />
  <DefinitionSchema definitions={definitions} />

  <Header currentPath="/technical-specifications" />
  <Analytics /> 

  <main>
  <section class="py-16">
      <div class="container mx-auto px-4 max-w-4xl">
          <h1 class="text-4xl font-bold text-center mb-4">Mobile Security Trailer Systems</h1>
          <p class="text-center text-sm text-gray-500 mb-10">Last reviewed: May 2026 &middot; Specs reflect units currently deployed across Pierce, King, Snohomish, and Kitsap counties.</p>
          <p class="text-lg mb-6">
            Our trailers are <strong>specifically designed and manufactured for year-round deployment in the Pacific Northwest climate</strong>.
            Built to withstand rainy and wet conditions that pose challenges for most electronics, our trailers feature
            <strong>weatherproof, secure, and vandal-resistant construction</strong> with advanced video and surveillance technology.
          </p>
      </div>
    </div>
        <div class="container mx-auto px-4 py-10">

    <div class="bg-gray-100 p-8 rounded-lg">
            <div class="relative w-full" style="padding-bottom: 56.25%;">
              <iframe
                src="https://www.youtube-nocookie.com/embed/WZh4h-t1D18?modestbranding=1&rel=0"
                class="absolute top-0 left-0 w-full h-full rounded-lg shadow-md"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen>
              </iframe>
            </div>
          </div>
          </div>
    <div class="container mx-auto px-4 py-10">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <!-- Camera Systems -->
        <div class="bg-white p-8 rounded-lg shadow-lg">
          <div class="w-16 h-16 bg-blue-100 rounded-full mx-auto mb-4 flex items-center justify-center">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="font-bold text-xl mb-3">Advanced Camera Infrastructure</h3>
          <ul class="space-y-2 text-gray-700">
            <li>• Single zone cameras for focused monitoring</li>
            <li>• Infrared PTZ cameras with night vision</li>
            <li>• 360-degree coverage capability</li>
            <li>• Support for up to 4 cameras per unit</li>
            <li>• Adjustable electric/hydraulic mast</li>
          </ul>
        </div>

        <!-- Power Systems -->
        <div class="bg-white p-8 rounded-lg shadow-lg">
          <div class="w-16 h-16 bg-green-100 rounded-full mx-auto mb-4 flex items-center justify-center">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
          </div>
          <h3 class="font-bold text-xl mb-3">Intelligent Power Management</h3>
          <ul class="space-y-2 text-gray-700">
            <li>• Solar panels for energy conservation</li>
            <li>• Backup gas generator for extended operation</li>
            <li>• Onsite power supply option available</li>
            <li>• Intelligent battery management system</li>
            <li>• Continuous operation in all weather</li>
          </ul>
        </div>

        <!-- Construction -->
        <div class="bg-white p-8 rounded-lg shadow-lg">
          <div class="w-16 h-16 bg-purple-100 rounded-full mx-auto mb-4 flex items-center justify-center">
            <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="font-bold text-xl mb-3">Robust Security Construction</h3>
          <ul class="space-y-2 text-gray-700">
            <li>• Reinforced steel construction</li>
            <li>• Easily transportable design</li>
            <li>• Hitch lock for trailer security</li>
            <li>• Wheel locks to prevent movement</li>
            <li>• Optional security boot available</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- S-VIDIA Technology Platform -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-12">S-VIDIA Video Security Platform</h2>
        
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <h3 class="text-2xl font-bold mb-4 text-blue-600">Advanced Technology Platform</h3>
            <p class="text-gray-700 mb-6">
              Our trailers feature the cutting-edge S-VIDIA video security platform, utilizing a unique video 
              compression method that ensures reliable, high-quality surveillance footage while minimizing bandwidth requirements.
            </p>
            
            <h4 class="font-bold text-lg mb-3">Key Capabilities:</h4>
            <ul class="space-y-3 text-gray-700">
              <li class="flex items-start">
                <svg class="w-5 h-5 text-green-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span>Remote access capabilities from any device</span>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-green-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span>4G/5G, Wi-Fi, and Starlink transmission options</span>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-green-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span>Video storage for 2 weeks before automatic looping</span>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-green-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span>Intelligent compression for efficient data transmission</span>
              </li>
            </ul>
          </div>
          <div class="bg-gray-100 p-8 rounded-lg">
            <LazyImage src="/images/onboard-computer.webp" alt="High-definition PTZ surveillance cameras mounted on mobile security trailer mast" 
              class="w-full h-full object-cover" width="600" height="400" />
            <p class="text-center text-gray-600 text-sm mt-4">
              S-VIDIA platform provides real-time monitoring and control
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Optional Advanced Features -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Optional Advanced Features</h2>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
        <!-- PA Speaker Systems -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <div class="w-12 h-12 bg-orange-100 rounded-full mb-4 flex items-center justify-center">
            <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"></path>
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">PA Speaker Systems</h3>
          <p class="text-gray-600 text-sm">
            Two-way audio communication for warnings and announcements
          </p>
        </div>

        <!-- Radar Detection -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <div class="w-12 h-12 bg-red-100 rounded-full mb-4 flex items-center justify-center">
            <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Radar Movement Detection</h3>
          <p class="text-gray-600 text-sm">
            Advanced radar technology detecting movement beyond 400+ feet
          </p>
        </div>

        <!-- Floodlights -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <div class="w-12 h-12 bg-yellow-100 rounded-full mb-4 flex items-center justify-center">
            <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Automatic Floodlights</h3>
          <p class="text-gray-600 text-sm">
            Motion-activated LED floodlights for enhanced deterrence
          </p>
        </div>

        <!-- License Plate Reader -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <div class="w-12 h-12 bg-indigo-100 rounded-full mb-4 flex items-center justify-center">
            <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">License Plate Reader</h3>
          <p class="text-gray-600 text-sm">
            Specialized cameras for automatic license plate recognition
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Specifications Detail -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Detailed Technical Specifications</h2>
      
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8">
          <!-- Power System Specs -->
          <div class="bg-gray-50 p-6 rounded-lg">
            <h3 class="font-bold text-xl mb-4 text-blue-600">Power System</h3>
            <table class="w-full text-left">
              <caption class="sr-only">Power System specifications for solar panels, battery system, generator, and shore power options</caption>
              <tbody class="space-y-2">
                <tr class="border-b">
                  <td class="py-2 font-semibold">Solar Panels:</td>
                  <td class="py-2">Energy efficient solar array</td>
                </tr>
                <tr class="border-b">
                  <td class="py-2 font-semibold">Battery System:</td>
                  <td class="py-2">Intelligent management with backup</td>
                </tr>
                <tr class="border-b">
                  <td class="py-2 font-semibold">Generator:</td>
                  <td class="py-2">Optional gas backup generator</td>
                </tr>
                <tr>
                  <td class="py-2 font-semibold">Shore Power:</td>
                  <td class="py-2">Onsite power connection available</td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Camera System Specs -->
          <div class="bg-gray-50 p-6 rounded-lg">
            <h3 class="font-bold text-xl mb-4 text-blue-600">Camera System</h3>
            <table class="w-full text-left">
              <caption class="sr-only">Camera System specifications for camera count, camera types, night vision, and coverage capability</caption>
              <tbody class="space-y-2">
                <tr class="border-b">
                  <td class="py-2 font-semibold">Camera Count:</td>
                  <td class="py-2">Up to 4 cameras per trailer</td>
                </tr>
                <tr class="border-b">
                  <td class="py-2 font-semibold">Camera Types:</td>
                  <td class="py-2">PTZ, Fixed, 360-degree</td>
                </tr>
                <tr class="border-b">
                  <td class="py-2 font-semibold">Night Vision:</td>
                  <td class="py-2">Infrared illumination</td>
                </tr>
                <tr>
                  <td class="py-2 font-semibold">Coverage:</td>
                  <td class="py-2">Complete 360-degree capability</td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Trailer Construction -->
          <div class="bg-gray-50 p-6 rounded-lg">
            <h3 class="font-bold text-xl mb-4 text-blue-600">Trailer Construction</h3>
            <table class="w-full text-left">
              <caption class="sr-only">Trailer Construction specifications for frame material, mast height, security features, and weatherproofing</caption>
              <tbody class="space-y-2">
                <tr class="border-b">
                  <td class="py-2 font-semibold">Frame:</td>
                  <td class="py-2">Reinforced steel construction</td>
                </tr>
                <tr class="border-b">
                  <td class="py-2 font-semibold">Mast Height:</td>
                  <td class="py-2">Adjustable electric/hydraulic</td>
                </tr>
                <tr class="border-b">
                  <td class="py-2 font-semibold">Security:</td>
                  <td class="py-2">Hitch lock, wheel locks, boot</td>
                </tr>
                <tr>
                  <td class="py-2 font-semibold">Weatherproofing:</td>
                  <td class="py-2">Pacific Northwest rated</td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Communication & Storage -->
          <div class="bg-gray-50 p-6 rounded-lg">
            <h3 class="font-bold text-xl mb-4 text-blue-600">Communication & Storage</h3>
            <table class="w-full text-left">
              <caption class="sr-only">Communication and Storage specifications for connectivity options, video security platform, storage capacity, and remote access capabilities</caption>
              <tbody class="space-y-2">
                <tr class="border-b">
                  <td class="py-2 font-semibold">Connectivity:</td>
                  <td class="py-2">4G/5G, Wi-Fi, Starlink</td>
                </tr>
                <tr class="border-b">
                  <td class="py-2 font-semibold">Platform:</td>
                  <td class="py-2">S-VIDIA video security</td>
                </tr>
                <tr class="border-b">
                  <td class="py-2 font-semibold">Storage:</td>
                  <td class="py-2">2 weeks continuous recording</td>
                </tr>
                <tr>
                  <td class="py-2 font-semibold">Access:</td>
                  <td class="py-2">Remote viewing capabilities</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2026 Field-Tested Deployments -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-4">2026 Field-Tested Deployments</h2>
        <p class="text-center text-gray-700 mb-12 max-w-3xl mx-auto">
