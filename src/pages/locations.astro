---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTASection from '../components/CTASection.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import QuickAnswer from '../components/QuickAnswer.astro';
import SpeakableSchema from '../components/SpeakableSchema.astro';
import { locationGroups, allLocations } from '../data/locations.js';

const title = "Service Areas | Mobile Surveillance Trailer Rental Across Puget Sound";
const description = "CCTV Trailer rents mobile surveillance trailers throughout the Puget Sound region — Tacoma, Seattle, Kent, Federal Way, Olympia, Bremerton, and every city in between. Same-day delivery across Pierce, King, Kitsap, and Thurston counties.";

const breadcrumbItems = [
  { name: "Home", url: "/" },
  { name: "Service Areas" }
];

const speakableSections = [
  { cssSelector: ".quick-answer-content" },
  { cssSelector: "#coverage-intro h2, #coverage-intro p" },
  { cssSelector: "#locations-faq h2, #locations-faq div" }
];

// LocalBusiness + ItemList schema. The ItemList tells Google we have a
// dedicated page per city, which strengthens the service-area graph.
const localBusinessSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "CCTV Trailer",
  "description": "Mobile surveillance trailer rental throughout the Puget Sound region.",
  "telephone": "(253) 683-2288",
  "email": "info@cctvtrailer.com",
  "url": "https://www.cctvtrailer.com/locations",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "222 E 26th St",
    "addressLocality": "Tacoma",
    "addressRegion": "WA",
    "postalCode": "98421",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 47.2529,
    "longitude": -122.4443
  },
  "areaServed": allLocations.map((l) => ({
    "@type": "City",
    "name": l.city.split("—")[0].trim(),
    "containedInPlace": { "@type": "State", "name": "Washington" }
  }))
});

const itemListSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Puget Sound Service Areas",
  "itemListElement": allLocations.map((l, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `https://www.cctvtrailer.com${l.href}`,
    "name": l.city
  }))
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Which Puget Sound cities does CCTV Trailer serve?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We deliver mobile surveillance trailers throughout Pierce, King, Kitsap, and Thurston counties. Core service areas include Tacoma, Seattle, Kent, Federal Way, Auburn, Puyallup, Fife, Lakewood/JBLM, Olympia, and Bremerton. Other Puget Sound cities are served on request with the same response times and pricing."
      }
    },
    {
      "@type": "Question",
      "name": "Is there a travel or delivery fee outside Tacoma?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Delivery and setup are included in the rental rate for any site within our standard Puget Sound service radius. For locations outside that radius or for same-day emergency dispatch, we confirm any mileage during quoting — there are never hidden fees."
      }
    },
    {
      "@type": "Question",
      "name": "How fast can you deploy a surveillance trailer in my area?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Standard deployment is same day or next business day for Pierce and South King County. Emergency same-day deployment is available 24/7 for the entire Puget Sound region. On-site setup typically takes 20–30 minutes."
      }
    },
    {
      "@type": "Question",
      "name": "What does a rental cost in my city?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Rental pricing is the same across every Puget Sound service area: $999 the first day, $499 for each additional day, $3,500/week, $8,000/month. All rates include delivery, setup, solar or generator power, and 24/7 support."
      }
    }
  ]
});
---

<Layout
  title={title}
  description={description}
  schema={[localBusinessSchema, itemListSchema, faqSchema]}
>
  <Header currentPath="/locations" />
  <BreadcrumbSchema items={breadcrumbItems} />
  <SpeakableSchema sections={speakableSections} />

  <main>
    <!-- Hero -->
    <section class="bg-gray-900 text-white py-16">
      <div class="container mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Puget Sound Service Areas</h1>
        <p class="text-xl text-gray-200 max-w-3xl mx-auto">
          Mobile surveillance trailers, delivered and monitored across Pierce, King, Kitsap, and Thurston counties. Same-day deployment, one price per city, zero surprises.
        </p>
        <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center">
          <a href="tel:2536832288" class="bg-green-600 hover:bg-green-700 text-white font-bold py-3 px-8 rounded-lg inline-block">
            📞 Call (253) 683-2288
          </a>
          <a href="/contact" class="bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-8 rounded-lg inline-block">
            Request a Quote
          </a>
        </div>
      </div>
    </section>

    <!-- Quick Answer -->
    <section class="py-8 bg-gray-50">
      <div class="container mx-auto px-4">
        <QuickAnswer
          what="Same mobile surveillance trailer fleet, delivered across the Puget Sound region"
          cost="<strong>$999</strong> first day, $499/additional day · $3,500/week · <strong>$8,000/month</strong>"
          time="Same-day or next-business-day delivery · <strong>20–30 min setup</strong>"
          coverage="Pierce · King · Kitsap · Thurston counties"
          availability="24/7 emergency dispatch across every service area"
          customFields={[
            { label: "Cities Served", value: `${allLocations.length} dedicated city pages + request-only coverage` },
            { label: "Transparent Pricing", value: "Same rate in every city — no travel surcharge inside the core radius" }
          ]}
        />
      </div>
    </section>

    <!-- Coverage intro -->
    <section id="coverage-intro" class="py-12 bg-white">
      <div class="container mx-auto px-4 max-w-4xl">
        <h2 class="text-3xl font-bold mb-4 text-gray-900">Coverage you can count on</h2>
        <p class="text-lg text-gray-700 leading-relaxed mb-4">
          CCTV Trailer has been locally owned in Tacoma since 2009. Over that time we have delivered and monitored surveillance trailers at construction sites, retail parking lots, events, and industrial facilities across every corner of the Puget Sound. Every service area on this page has a dedicated page with local context, landmarks, and crime data — pick your city below to see how we deploy there.
        </p>
        <p class="text-lg text-gray-700 leading-relaxed">
          Don't see your exact city? We routinely dispatch to <strong>Gig Harbor, Renton, Bellevue, Everett, Kirkland, Redmond, Sammamish, Lacey, and Bellingham</strong> and will deliver anywhere reachable on I-5, I-405, or SR-16 on the same schedule. Just call us at <a href="tel:2536832288" class="text-red-600 hover:text-red-700 font-semibold">(253) 683-2288</a>.
        </p>
      </div>
    </section>

    <!-- Service area groups -->
    <section class="py-12 bg-gray-50">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold text-center mb-10">Service areas by region</h2>
        <div class="grid lg:grid-cols-3 gap-8">
          {locationGroups.map((group) => (
            <div class="bg-white rounded-lg shadow-md p-6 border border-gray-200">
              <h3 class="text-xl font-semibold mb-4 text-gray-900">{group.label}</h3>
              <ul class="space-y-3">
                {group.cities.map((c) => (
                  <li>
                    <a href={c.href} class="block group">
                      <span class="block text-red-600 group-hover:text-red-700 font-semibold">{c.city}</span>
                      <span class="block text-sm text-gray-600 group-hover:text-gray-800">{c.angle}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Trust / pricing reminder -->
    <section class="py-12 bg-white">
      <div class="container mx-auto px-4 max-w-4xl text-center">
        <h2 class="text-2xl font-bold mb-4">One price, every Puget Sound city</h2>
        <p class="text-lg text-gray-700 mb-6">
          No travel surcharge inside our core service radius. Full rates and what's included:
        </p>
        <a href="/pricing" class="bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-8 rounded-lg inline-block">
          See Pricing & Plans
        </a>
      </div>
    </section>

    <!-- FAQ -->
    <section id="locations-faq" class="py-16 bg-gray-50">
      <div class="container mx-auto px-4 max-w-4xl">
        <h2 class="text-3xl font-bold text-center mb-10">Service area FAQ</h2>

        <div class="space-y-6">
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="font-semibold text-lg mb-2">Which Puget Sound cities does CCTV Trailer serve?</h3>
            <p class="text-gray-700">We deliver mobile surveillance trailers throughout Pierce, King, Kitsap, and Thurston counties. Core service areas include Tacoma, Seattle, Kent, Federal Way, Auburn, Puyallup, Fife, Lakewood/JBLM, Olympia, and Bremerton. Other Puget Sound cities are served on request with the same response times and pricing.</p>
          </div>
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="font-semibold text-lg mb-2">Is there a travel or delivery fee outside Tacoma?</h3>
            <p class="text-gray-700">Delivery and setup are included in the rental rate for any site within our standard Puget Sound service radius. For locations outside that radius or for same-day emergency dispatch, we confirm any mileage during quoting — there are never hidden fees.</p>
          </div>
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="font-semibold text-lg mb-2">How fast can you deploy a surveillance trailer in my area?</h3>
            <p class="text-gray-700">Standard deployment is same day or next business day for Pierce and South King County. Emergency same-day deployment is available 24/7 for the entire Puget Sound region. On-site setup typically takes 20–30 minutes.</p>
          </div>
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="font-semibold text-lg mb-2">What does a rental cost in my city?</h3>
            <p class="text-gray-700">Rental pricing is the same across every Puget Sound service area: $999 the first day, $499 for each additional day, $3,500/week, $8,000/month. All rates include delivery, setup, solar or generator power, and 24/7 support. Full breakdown on the <a href="/pricing" class="text-red-600 hover:text-red-700 underline">pricing page</a>.</p>
          </div>
        </div>
      </div>
    </section>

    <CTASection
      title="Need a trailer in your city?"
      description="Tell us where and when — we'll confirm availability and quote inside the hour."
      features={["✓ Same-day Puget Sound delivery", "✓ One price in every city", "✓ 24/7 dispatch"]}
    />
  </main>

  <Footer />
</Layout>
