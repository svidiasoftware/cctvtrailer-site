                {
                  value: "22,230",
                  label: "Total crimes reported in Tacoma, 2024",
                  icon: "📊",
                  highlight: false,
                  source: {
                    text: "AreaVibes Crime Data",
                    url: "https://www.areavibes.com/tacoma-wa/crime/"
                  }
                },
                {
                  value: "$400K",
                  label: "Vandalism damage to South Park alone",
                  icon: "🔨",
                  highlight: true,
                  source: {
                    text: "Metro Parks Tacoma Board Minutes, March 2025",
                    url: "https://www.parkstacoma.gov/wp-content/uploads/2025/04/March-24_-2025-Regular-Board-Meeting-Minutes.pdf"
                  }
