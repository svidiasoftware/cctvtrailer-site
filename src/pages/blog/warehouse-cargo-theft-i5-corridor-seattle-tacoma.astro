                  }
                },
                {
                  value: "#5",
                  label: "Washington's national ranking for cargo theft incidents",
                  icon: "⚠️",
                  highlight: true,
                  source: {
                    text: "National Insurance Crime Bureau",
                    url: "https://www.nicb.org/news/news-releases/nicb-warns-increased-cargo-theft-2025"
                  }
                },
                {
