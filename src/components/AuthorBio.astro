---
// -----------------------------------------------------------------------------
// AuthorBio.astro — visible author card for blog posts.
//
// E-E-A-T note: the accompanying Person schema lives inline in each blog
// post's BlogPosting JSON-LD (see scripts/update-blog-authors.mjs or the
// individual post frontmatter). We intentionally do NOT emit a duplicate
// Person graph here, because Google prefers a single authoritative Person
// node per page rather than a mirrored one.
//
// Usage:
//   import AuthorBio from '../../components/AuthorBio.astro';
//   ...
//   <AuthorBio />
// -----------------------------------------------------------------------------

interface Props {
  /**
   * Optional custom intro label. Defaults to "Written by".
   */
  label?: string;
}

const { label = 'Written by' } = Astro.props as Props;
---

<aside class="author-bio bg-gray-50 border border-gray-200 rounded-lg p-6 my-10 flex items-start gap-4" aria-label="Author biography">
  <div class="flex-shrink-0 w-16 h-16 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 text-xl font-bold select-none" aria-hidden="true">
    VZ
  </div>
  <div class="min-w-0">
    <p class="text-sm text-gray-500 mb-1">{label}</p>
    <p class="font-bold text-gray-900 text-lg leading-tight">
      <a href="/about" class="hover:text-blue-700 transition-colors">Val Zakharov</a>
    </p>
    <p class="text-gray-700 text-sm mt-2 leading-relaxed">
      15 years in the Pacific Northwest mobile surveillance and security industry &mdash; construction jobsite, warehouse, and event-security deployments across Pierce, King, Snohomish, and Kitsap counties.
    </p>
    <p class="mt-2">
      <a href="/about" class="text-blue-600 hover:underline text-sm font-medium">Learn more about our team &rarr;</a>
    </p>
  </div>
</aside>
