<style>
  .boom-map-figure {
    margin: 2.5rem auto;
    max-width: 760px;
  }
  .boom-map-svg-wrap {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 16px;
    margin: 0 auto;
  }
  .boom-map-svg-wrap svg {
    display: block;
    width: 100%;
    height: auto;
    max-height: 720px;
  }
  .boom-map-caption {
    margin-top: 0.75rem;
    text-align: center;
    color: #475569;
    font-size: 0.875rem;
    font-style: italic;
  }
  .boom-map-key {
    margin-top: 1.5rem;
    list-style: none;
    padding-left: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem 1.5rem;
    font-size: 0.9375rem;
    color: #1f2937;
  }
  @media (min-width: 640px) {
    .boom-map-key {
      grid-template-columns: 1fr 1fr;
    }
  }
  .boom-map-key li {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    line-height: 1.4;
  }
  .key-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 1.5rem;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 9999px;
    color: white;
    font-weight: 700;
    font-size: 0.75rem;
    line-height: 1;
  }
  .key-transit    { background: #1d4ed8; }
  .key-corp       { background: #9333ea; }
  .key-warehouse  { background: #15803d; }
  .key-industrial { background: #b45309; }
  .key-military   { background: #475569; }
</style>
